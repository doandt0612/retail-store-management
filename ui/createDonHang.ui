  <property name="styleSheet">
   <string notr="true">/* 1. Thiết lập nền tảng */
QDialog {
    background-color: #f3f4f6;
    font-family: &quot;Inter&quot;, &quot;Segoe UI&quot;, sans-serif;
}

/* 2. Thẻ nội dung (Cards) */
QFrame#frame, QFrame#frame_2, QFrame#frame_3, QFrame#frame_4 {
    background-color: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
}

/* 3. Tiêu đề và Nhãn */
QLabel#lblTitleTaoDonHang { font-size: 26px; font-weight: 800; color: #111827; }
QLabel#lblThemSanPham, QLabel#lblDanhSachSP, QLabel#lblThongTinDatHang, QLabel#lblTomTatDonHang {
    font-size: 17px; font-weight: 700; color: #111827;
}

/* 4. Ô nhập liệu (SpinBox &amp; ComboBox) */
QComboBox, QSpinBox {
    background-color: #ffffff;
    border: 1px solid #d1d5db;
    border-radius: 8px;
    padding: 8px 12px;
    color: #111827;
    min-height: 22px;
}

/* Khi click vào ô sẽ hiện viền xanh */
QComboBox:focus, QSpinBox:focus {
    border: 2px solid #2563eb;
}

/* 5. Nút bấm (Đã chỉnh nhỏ btnTaoDonHang) */
QPushButton#btnThem, QPushButton#btnTaoDonHang {
    background-color: #2563eb;
    color: white;
    font-weight: 700;
    font-size: 13px;
    border-radius: 8px;
    padding: 10px 20px;
}

QPushButton:hover { background-color: #1d4ed8; }

/* 6. Bảng danh sách */
QTableWidget { background-color: #ffffff; border: none; gridline-color: transparent; }
QHeaderView::section {
    background-color: #ffffff; padding: 12px; border: none;
    border-bottom: 2px solid #f3f4f6; font-weight: bold;
    color: #6b7280; text-transform: uppercase; font-size: 11px;
}

/* 7. Hiển thị kết quả tóm tắt */
QLabel#lblHienThiSoMon { font-size: 16px; font-weight: 700; }
QLabel#lblHienThiSoTienTongCong { font-size: 26px; font-weight: 800; color: #2563eb; }</string>
