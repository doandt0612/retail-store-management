<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>Dialog</class>
 <widget class="QDialog" name="Dialog">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>400</width>
    <height>249</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>Dialog</string>
  </property>
  <property name="styleSheet">
   <string notr="true">/* 1. Tổng thể Cửa sổ Dialog */
QDialog {
    background-color: #ffffff;
    font-family: &quot;Inter&quot;, &quot;Segoe UI&quot;, sans-serif;
}

/* 2. Tiêu đề chính (Cập nhật tồn kho) */
QLabel#lblTitleCapNhatTonKho {
    font-size: 20px;
    font-weight: 700; /* Bold */
    color: #111827;   /* Đen tuyền chuyên nghiệp */
    padding-bottom: 5px;
    margin-bottom: 10px;
}

/* 3. Nhãn thuộc tính (Số lượng) */
QLabel#lblSoLuongTonKho {
    font-size: 13px;
    font-weight: 600; /* Semi-bold */
    color: #4b5563;   /* Xám đậm */
}

/* 4. Ô nhập số lượng (QSpinBox) */
QSpinBox#spnSoLuongTonKho {
    background-color: #f9fafb;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    padding: 8px 12px;
    color: #111827;
    min-height: 25px;
}

/* Hiệu ứng khi chọn vào SpinBox */
QSpinBox#spnSoLuongTonKho:focus {
    border: 2px solid #2563eb; /* Viền xanh dương thương hiệu */
    background-color: #ffffff;
}

/* 5. Dòng lưu ý nhỏ bên dưới */
QLabel#lblLuuY {
    font-size: 12px;
    color: #6b7280; /* Màu xám nhạt để làm dịu thông tin phụ */
    font-style: italic;
}

/* 6. Nút bấm chức năng (Footer Buttons) */

/* Nút LƯU (Màu xanh dương) */
QPushButton#btnLuu {
    background-color: #2563eb;
    color: #ffffff;
    font-weight: 700;
    border-radius: 8px;
    padding: 12px 24px;
    min-width: 120px;
}

QPushButton#btnLuu:hover {
    background-color: #1d4ed8;
}

/* Nút HỦY (Trắng viền xám) */
QPushButton#btnHuy {
    background-color: #ffffff;
    color: #374151;
    border: 1px solid #d1d5db;
    border-radius: 8px;
    padding: 12px 24px;
}

QPushButton#btnHuy:hover {
    background-color: #f3f4f6;
}</string>
  </property>
  <layout class="QVBoxLayout" name="verticalLayout">
   <item>
    <widget class="QLabel" name="lblTitleCapNhatTonKho">
     <property name="text">
      <string>Cập nhật tồn kho</string>
     </property>
     <property name="alignment">
      <set>Qt::AlignCenter</set>
     </property>
    </widget>
   </item>
   <item>
    <layout class="QFormLayout" name="formLayout">
     <item row="0" column="0">
      <widget class="QLabel" name="lblSoLuongTonKho">
       <property name="text">
        <string>Số lượng</string>
       </property>
      </widget>
     </item>
     <item row="0" column="1">
      <widget class="QSpinBox" name="spnSoLuongTonKho">
       <property name="maximum">
        <number>1000</number>
       </property>
      </widget>
     </item>
    </layout>
   </item>
   <item>
    <widget class="QLabel" name="lblLuuY">
     <property name="text">
      <string>Lưu ý: Số lượng tồn kho không được âm.</string>
     </property>
    </widget>
   </item>
   <item>
    <layout class="QHBoxLayout" name="horizontalLayout">
     <item>
      <widget class="QPushButton" name="btnLuu">
       <property name="text">
        <string>Lưu thay đổi</string>
       </property>
      </widget>
     </item>
     <item>
      <widget class="QPushButton" name="btnHuy">
       <property name="text">
        <string>Hủy</string>
       </property>
      </widget>
     </item>
    </layout>
   </item>
  </layout>
 </widget>
 <resources/>
 <connections/>
</ui>
