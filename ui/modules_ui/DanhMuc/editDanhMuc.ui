<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>Dialog</class>
 <widget class="QDialog" name="Dialog">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>400</width>
    <height>380</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>Dialog</string>
  </property>
  <property name="styleSheet">
   <string notr="true">/* 1. Tổng thể Cửa sổ Dialog  */
QDialog {
    background-color: #f3f4f6; /* Nền xám nhạt đồng bộ toàn hệ thống */
    font-family: &quot;Inter&quot;, &quot;Segoe UI&quot;, sans-serif;
}

/* 2. Tiêu đề chính [cite: 108, 514] */
QLabel#lblTitleChinhSuaDanhMuc {
    font-size: 26px;
    font-weight: 800; /* Extra Bold */
    color: #111827;   /* Đen tuyền */
    padding: 10px 0px;
}

/* 3. Nhãn thuộc tính (Labels) [cite: 113, 519] */
QLabel#lblMaSP, QLabel#lblTenSP, QLabel#lblDanhMuc {
    font-size: 13px;
    font-weight: 600; /* Semi-bold */
    color: #4b5563;   /* Xám đậm chuyên nghiệp */
}

/* 4. Các ô nhập liệu (Inputs) [cite: 520-522] */
QLineEdit, QComboBox {
    background-color: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    padding: 8px 12px;
    color: #111827;
}

/* Hiệu ứng khi focus [cite: 521-522] */
QLineEdit:focus, QComboBox:focus {
    border: 2px solid #2563eb; /* Xanh dương thương hiệu */
}

/* Ô Read-Only [cite: 522-523] */
QLineEdit[readOnly=&quot;true&quot;] {
    background-color: #f3f4f6;
    color: #6b7280;
}

/* 5. Nút bấm (Buttons) [cite: 523-525, 562] */
/* Nút LƯU */
QPushButton#btnLuu {
    background-color: #2563eb;
    color: #ffffff;
    font-weight: 700;
    border-radius: 8px;
    padding: 10px 24px;
}

QPushButton#btnLuu:hover {
    background-color: #1d4ed8;
}

/* Nút HỦY */
QPushButton#btnHuy {
    background-color: #ffffff;
    color: #374151;
    border: 1px solid #d1d5db;
    border-radius: 8px;
    padding: 10px 24px;
}

QPushButton#btnHuy:hover {
    background-color: #f9fafb;
}</string>
  </property>
  <layout class="QVBoxLayout" name="verticalLayout">
   <item>
    <widget class="QLabel" name="lblTitleChinhSuaDanhMuc">
     <property name="text">
      <string>Chỉnh sửa danh mục</string>
     </property>
     <property name="alignment">
      <set>Qt::AlignCenter</set>
     </property>
    </widget>
   </item>
   <item>
    <layout class="QFormLayout" name="formLayout">
     <item row="0" column="0">
      <widget class="QLabel" name="lblDanhMuc">
       <property name="text">
        <string>Danh mục</string>
       </property>
      </widget>
     </item>
     <item row="0" column="1">
      <widget class="QComboBox" name="cbDanhMuc"/>
     </item>
     <item row="1" column="0">
      <widget class="QLabel" name="lblMaSP">
       <property name="text">
        <string>Mã sản phẩm</string>
       </property>
      </widget>
     </item>
     <item row="1" column="1">
      <widget class="QLineEdit" name="txtReadOnlyMaSP">
       <property name="readOnly">
        <bool>true</bool>
       </property>
      </widget>
     </item>
     <item row="2" column="0">
      <widget class="QLabel" name="lblTenSP">
       <property name="text">
        <string>Tên sản phẩm</string>
       </property>
      </widget>
     </item>
     <item row="2" column="1">
      <widget class="QComboBox" name="cbTenSP"/>
     </item>
    </layout>
   </item>
   <item>
    <layout class="QHBoxLayout" name="horizontalLayout">
     <item>
      <widget class="QPushButton" name="btnLuu">
       <property name="text">
        <string>Lưu thay đổi</string>
       </property>
      </widget>
     </item>
     <item>
      <widget class="QPushButton" name="btnHuy">
       <property name="text">
        <string>Hủy</string>
       </property>
      </widget>
     </item>
    </layout>
   </item>
  </layout>
 </widget>
