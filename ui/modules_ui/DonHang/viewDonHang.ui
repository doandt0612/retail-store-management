  <property name="styleSheet">
   <string notr="true">/* 1. Tổng thể Cửa sổ [cite: 851-853] */
QDialog {
    background-color: #f3f4f6; /* Nền xám nhạt làm nổi bật các Card trắng */
    font-family: &quot;Inter&quot;, &quot;Segoe UI&quot;, sans-serif;
}

/* 2. Tiêu đề trang chính (Chi tiết đơn hàng) [cite: 853-855] */
QLabel#lblTitleChiTietDonHang {
    font-size: 26px;
    font-weight: 800; /* Extra bold */
    color: #111827;   /* Đen tuyền hiện đại */
    padding: 10px 0px;
}

/* 3. Thẻ nội dung (Cards) [cite: 855-856] */
QFrame#frame, QFrame#frame_2, QFrame#frame_3 {
    background-color: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 12px; /* Bo góc đồng bộ toàn hệ thống */
}

/* 4. Tiêu đề các khối con [cite: 856-858] */
QLabel#lblDanhSachSP, QLabel#lblThongTinChung, QLabel#lblThongTinThanhToan {
    font-size: 17px;
    font-weight: 700;
    color: #111827;
    margin-bottom: 5px;
}

/* 5. Nhãn thuộc tính (Labels) [cite: 858-860] */
QLabel#lblMaDon, QLabel#lblNgayMua, QLabel#lblKhachHang, QLabel#lblTongTien, 
QLabel#lblTrangThai, QLabel#lblMaHoaDon, QLabel#lblNgayThanhToan, 
QLabel#lblTongTienThanhToan, QLabel#lblPhuongThucThanhToan {
    font-size: 13px;
    font-weight: 600;
    color: #4b5563; /* Màu xám đậm giúp dịu mắt */
}

/* 6. Nhãn dữ liệu (Values) [cite: 860-861] */
QLabel#lblHienThiMaDon_2, QLabel#lblHienThiNgayMua, QLabel#lblHienThiKhachHang, 
QLabel#lblHienThiTrangThai, QLabel#lblHienThiTongTien, QLabel#lblHienThiMaHoaDon, 
QLabel#lblHienThiNgayThanhToan, QLabel#lblHienThiTongTienThanhToan, 
QLabel#lblHienThiPhuongThucThanhToan {
    font-size: 14px;
    font-weight: 500;
    color: #111827;
    padding: 5px 0px;
}

/* 7. Nút bấm (Ví dụ: Nút Sửa) [cite: 868] */
QPushButton#btnSua {
    background-color: #2563eb; /* Màu xanh dương thương hiệu */
    color: #ffffff;
    font-weight: 700;
    border-radius: 8px;
    padding: 8px 20px;
}

QPushButton#btnSua:hover {
    background-color: #1d4ed8;
}

/* 8. Bảng dữ liệu [cite: 863-866, 869-872] */
QTableWidget#tblDanhSachSP {
    background-color: #ffffff;
    border: none;
    gridline-color: transparent;
    outline: none;
}

QHeaderView::section {
    background-color: #ffffff;
    padding: 12px;
    border: none;
    border-bottom: 2px solid #f3f4f6;
    font-weight: bold;
    color: #6b7280;
    text-transform: uppercase; /* BUỘC IN HOA TIÊU ĐỀ CỘT */
    font-size: 11px;
}</string>
