  <property name="styleSheet">
   <string notr="true">/* 1. Tổng thể Cửa sổ và Phông chữ [cite: 839, 840] */
QDialog {
    background-color: #f3f4f6; /* Nền xám nhạt làm nổi bật các Card trắng */
    font-family: &quot;Inter&quot;, &quot;Segoe UI&quot;, sans-serif;
}

/* 2. Tiêu đề chính trang (Chỉnh sửa đơn hàng) [cite: 841, 842] */
QLabel#lblTitleTaoDonHang {
    font-size: 26px;
    font-weight: 800;
    color: #111827;
    padding: 10px 0px;
}

/* 3. Thẻ nội dung (Cards) [cite: 843] */
QFrame#frame, QFrame#frame_2, QFrame#frame_3, QFrame#frame_4 {
    background-color: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
}

/* 4. Tiêu đề các khối con [cite: 844, 845] */
QLabel#lblThemSP, QLabel#lblDanhSachSP, QLabel#lblThongTinChung, QLabel#lblThongTinThanhToan {
    font-size: 17px;
    font-weight: 700;
    color: #111827;
    background-color: transparent;
    border: none;
    margin-bottom: 5px;
}

/* 5. Nhãn mô tả thuộc tính (Labels - Key) [cite: 845, 846] */
QLabel#lblSanPham, QLabel#lblSoLuong, QLabel#lblDonGia,
QLabel#lblMaDon, QLabel#lblNgayMua, QLabel#lblKhachHang, 
QLabel#lblTongTien, QLabel#lblTrangThai, QLabel#lblMaHoaDon, 
QLabel#lblNgayThanhToan, QLabel#lblTongTienThanhToan, QLabel#lblPhuongThucThanhToan {
    font-size: 13px;
    font-weight: 600;
    color: #4b5563; /* Màu xám đậm chuyên nghiệp */
}

/* 6. Ô nhập liệu và Chọn lựa (Inputs) [cite: 846-848] */
QLineEdit, QComboBox, QSpinBox, QDateTimeEdit {
    background-color: #f9fafb;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    padding: 8px 12px;
    color: #111827;
}

/* Hiệu ứng khi nhấn vào ô nhập liệu hoặc ô ReadOnly */
QLineEdit:focus, QComboBox:focus, QSpinBox:focus, QDateTimeEdit:focus {
    border: 2px solid #2563eb; /* Viền xanh dương thương hiệu [cite: 849] */
    background-color: #ffffff;
}

QLineEdit[readOnly=&quot;true&quot;] {
    background-color: #f3f4f6; /* Làm mờ các ô không cho sửa [cite: 850] */
    color: #6b7280;
}

/* 7. Các nút bấm hành động [cite: 851, 852] */
/* Nút chính (Lưu, Thêm) */
QPushButton#btnLuu, QPushButton#btnThem {
    background-color: #2563eb;
    color: #ffffff;
    font-weight: 700;
    border-radius: 8px;
    padding: 10px 20px;
}

QPushButton:hover {
    background-color: #1d4ed8;
}

/* Nút phụ (Hủy) */
QPushButton#btnHuy {
    background-color: #ffffff;
    color: #374151;
    border: 1px solid #d1d5db;
    border-radius: 8px;
    padding: 10px 20px;
}

/* 8. Bảng danh sách sản phẩm [cite: 852-855] */
QTableWidget#tblDanhSachSP {
    background-color: #ffffff;
    border: none;
    gridline-color: transparent;
    outline: none;
}

QHeaderView::section {
    background-color: #ffffff;
    padding: 12px;
    border: none;
    border-bottom: 2px solid #f3f4f6;
    font-weight: bold;
    color: #6b7280;
    text-transform: uppercase; /* BUỘC IN HOA TIÊU ĐỀ CỘT [cite: 5, 854] */
    font-size: 11px;
}</string>
