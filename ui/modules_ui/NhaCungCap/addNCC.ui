  <property name="styleSheet">
   <string notr="true">/* 1. Tổng thể Cửa sổ và Phông chữ  */
QDialog {
    background-color: #f3f4f6; /* Nền xám nhạt làm nổi bật các Card trắng */
    font-family: &quot;Inter&quot;, &quot;Segoe UI&quot;, sans-serif;
}

/* 2. Tiêu đề chính trang (Chỉnh sửa nhà cung cấp) [cite: 634, 635] */
QLabel#lblThemNCC {
    font-size: 26px;
    font-weight: 800;
    color: #111827;
    padding: 10px 0px;
}

/* 3. Thẻ nội dung (Cards) [cite: 635, 636] */
QFrame#frame, QFrame#frame_2, QFrame#frame_3 {
    background-color: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
}

/* 4. Tiêu đề các khối con [cite: 636, 637, 663, 671] */
QLabel#lblThemSPCungCap, QLabel#lblDanhSachSPCungCap, QLabel#lblThongTinLienHe {
    font-size: 17px;
    font-weight: 700;
    color: #111827;
    background-color: transparent;
    border: none;
    margin-bottom: 5px;
}

/* 5. Nhãn mô tả thuộc tính (Labels - Key) [cite: 638, 639] */
QLabel#lblMaSP, QLabel#lblTenSP, QLabel#lblSoLuong, QLabel#lblGiaNhap,
QLabel#lblMaNCC, QLabel#lblSDT, QLabel#lblEmail, QLabel#lblDiaChi {
    font-size: 13px;
    font-weight: 600;
    color: #4b5563; /* Màu xám đậm chuyên nghiệp */
}

/* 6. Ô nhập liệu và Chọn lựa (Inputs) [cite: 639, 640] */
QLineEdit, QComboBox, QSpinBox {
    background-color: #f9fafb;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    padding: 8px 12px;
    color: #111827;
}

/* Hiệu ứng khi nhấn vào ô nhập liệu hoặc ô ReadOnly [cite: 641, 642, 643] */
QLineEdit:focus, QComboBox:focus, QSpinBox:focus {
    border: 2px solid #2563eb;
    background-color: #ffffff;
}

QLineEdit[readOnly=&quot;true&quot;] {
    background-color: #f3f4f6; /* Làm mờ các ô không cho sửa */
    color: #6b7280;
}

/* 7. Các nút bấm hành động [cite: 643, 644] */
/* Nút chính (Lưu, Thêm) */
QPushButton#btnLuu, QPushButton#btnThem {
    background-color: #2563eb;
    color: #ffffff;
    font-weight: 700;
    border-radius: 8px;
    padding: 10px 20px;
}

QPushButton:hover {
    background-color: #1d4ed8;
}

/* Nút phụ (Hủy) [cite: 645, 646] */
QPushButton#btnHuy {
    background-color: #ffffff;
    color: #374151;
    border: 1px solid #d1d5db;
    border-radius: 8px;
    padding: 10px 20px;
}

QPushButton#btnHuy:hover {
    background-color: #f9fafb;
}

/* 8. Bảng danh sách sản phẩm cung cấp [cite: 646, 647, 664] */
QTableWidget#tblDanhSachSPCungCap {
    background-color: #ffffff;
    border: none;
    gridline-color: transparent;
    outline: none;
}

QHeaderView::section {
    background-color: #ffffff;
    padding: 12px;
    border: none;
    border-bottom: 2px solid #f3f4f6;
    font-weight: bold;
    color: #6b7280;
    text-transform: uppercase; /* BUỘC IN HOA TIÊU ĐỀ CỘT [cite: 648] */
    font-size: 11px;
}</string>
  </property>
