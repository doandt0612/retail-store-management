  <property name="styleSheet">
   <string notr="true">/* 1. Tổng thể Cửa sổ [cite: 419-421] */
QDialog {
    background-color: #f3f4f6; /* Nền xám nhạt làm nổi bật thẻ trắng */
    font-family: &quot;Inter&quot;, &quot;Segoe UI&quot;, sans-serif;
}

/* 2. Tiêu đề chính trang [cite: 421-422] */
QLabel#lblXemChiTietNCC {
    font-size: 26px;
    font-weight: 800;
    color: #111827;
    padding: 10px 0px;
}

/* 3. Thẻ nội dung (Cards) [cite: 422-423] */
QFrame#frame, QFrame#frame_2, QFrame#frame_3 {
    background-color: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
}

/* 4. Tiêu đề các khối con [cite: 423-424] */
QLabel#lblDanhSachSPCungCap, QLabel#lblThongTinLienHe, QLabel#lblDonHangNhap {
    font-size: 17px;
    font-weight: 700;
    color: #111827;
    background-color: transparent;
    border: none;
    margin-bottom: 5px;
}

/* 5. Nhãn mô tả thuộc tính (Labels) [cite: 424-425] */
QLabel#lblMaNCC, QLabel#lblSDT, QLabel#lblEmail, QLabel#lblDiaChi,
QLabel#lblMaDonNhap, QLabel#lblNgayNhap, QLabel#lblTongTien {
    font-size: 13px;
    font-weight: 600;
    color: #4b5563; /* Màu xám đậm chuyên nghiệp */
}

/* 6. Nhãn hiển thị giá trị thực tế (Values) [cite: 425-426] */
QLabel#lblHienThiMaNCC, QLabel#lblHienThiSDT, QLabel#lblHienThiEmail, 
QLabel#lblHienThiDiaChi, QLabel#lblHienThiMaDonNhap, 
QLabel#lblHienThiNgayNhap, QLabel#lblHienThiTongTien {
    font-size: 14px;
    font-weight: 500;
    color: #111827;
    padding: 5px 0px;
}

/* 7. Nút bấm (Buttons) [cite: 427-428] */
QPushButton#btnXemDonNhap, QPushButton#btnSua {
    background-color: #2563eb; /* Xanh dương thương hiệu */
    color: #ffffff;
    font-weight: 700;
    border-radius: 8px;
    padding: 10px 20px;
}

QPushButton:hover {
    background-color: #1d4ed8;
}

/* 8. Bảng danh sách sản phẩm [cite: 429-432] */
QTableWidget#tblDanhSachSPCungCap {
    background-color: #ffffff;
    border: none;
    gridline-color: transparent;
    outline: none;
}

QHeaderView::section {
    background-color: #ffffff;
    padding: 12px;
    border: none;
    border-bottom: 2px solid #f3f4f6;
    font-weight: bold;
    color: #6b7280;
    text-transform: uppercase; /* BUỘC IN HOA TIÊU ĐỀ CỘT */
    font-size: 11px;
}</string>
