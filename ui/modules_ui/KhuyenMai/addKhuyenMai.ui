  <property name="styleSheet">
   <string notr="true">/* 1. Tổng thể Cửa sổ và Phông chữ [cite: 734-736] */
QDialog {
    background-color: #f3f4f6; /* Nền xám nhạt làm nổi bật các Card trắng */
    font-family: &quot;Inter&quot;, &quot;Segoe UI&quot;, sans-serif;
}

/* 2. Tiêu đề trang chính (Chỉnh sửa khuyến mãi) [cite: 737-739, 750] */
QLabel#lblTitleTaoKM {
    font-size: 26px;
    font-weight: 800; /* Extra bold */
    color: #111827;   /* Đen tuyền chuyên nghiệp */
    padding: 10px 0px;
}

/* 3. Thẻ nội dung (Cards) [cite: 740, 751, 756, 763] */
QFrame#frame, QFrame#frame_2, QFrame#frame_3 {
    background-color: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 12px; /* Bo góc đồng bộ toàn hệ thống */
}

/* 4. Tiêu đề các khối con [cite: 741, 751, 757, 764] */
QLabel#lblThemSPCTKM, QLabel#lblDanhSachSP, QLabel#lblThongTinChung {
    font-size: 17px;
    font-weight: 700;
    color: #111827;
    background-color: transparent;
    border: none;
    margin-bottom: 5px;
}

/* 5. Nhãn mô tả thuộc tính (Labels - Key) [cite: 742, 753, 765-768] */
QLabel#lblSP, QLabel#lblTenCTKM, QLabel#lblNgayBatDau, 
QLabel#lblNgayKetThuc, QLabel#lblGiaTriGiam {
    font-size: 13px;
    font-weight: 600; /* Semi-bold */
    color: #4b5563;   /* Màu xám đậm chuyên nghiệp */
}

/* 6. Ô nhập liệu và Chọn lựa (Inputs) [cite: 769-771] */
QLineEdit, QComboBox, QDateEdit {
    background-color: #f9fafb;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    padding: 8px 12px;
    color: #111827;
}

QLineEdit:focus, QComboBox:focus, QDateEdit:focus {
    border: 2px solid #2563eb; /* Viền xanh dương thương hiệu */
    background-color: #ffffff;
}

/* 7. Các nút bấm hành động [cite: 744-745, 755, 772-773] */
/* Nút chính (Lưu, Thêm) */
QPushButton#btnLuu, QPushButton#btnThemSPCTKM {
    background-color: #2563eb;
    color: #ffffff;
    font-weight: 700;
    border-radius: 8px;
    padding: 10px 20px;
}

QPushButton:hover {
    background-color: #1d4ed8;
}

/* Nút phụ (Hủy) */
QPushButton#btnHuy {
    background-color: #ffffff;
    color: #374151;
    border: 1px solid #d1d5db;
    border-radius: 8px;
    padding: 10px 20px;
}

/* 8. Bảng danh sách sản phẩm áp dụng [cite: 746-749, 758-761] */
QTableWidget#tblDanhSachSP {
    background-color: #ffffff;
    border: none;
    gridline-color: transparent;
    outline: none;
}

QHeaderView::section {
    background-color: #ffffff;
    padding: 12px;
    border: none;
    border-bottom: 2px solid #f3f4f6;
    font-weight: bold;
    color: #6b7280;
    text-transform: uppercase; /* BUỘC IN HOA TIÊU ĐỀ CỘT */
    font-size: 11px;
}</string>
