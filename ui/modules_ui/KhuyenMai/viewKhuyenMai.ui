  <property name="styleSheet">
   <string notr="true">/* 1. Tổng thể Cửa sổ [cite: 697-699] */
QDialog {
    background-color: #f3f4f6; /* Nền xám nhạt làm nổi bật các Card trắng */
    font-family: &quot;Inter&quot;, &quot;Segoe UI&quot;, sans-serif;
}

/* 2. Tiêu đề trang chính (Chi tiết khuyến mãi) [cite: 699-702, 712] */
QLabel#lblTitleChiTietKM {
    font-size: 26px;
    font-weight: 800; /* Extra bold */
    color: #111827;   /* Đen tuyền chuyên nghiệp */
    padding: 10px 0px;
}

/* 3. Thẻ nội dung (Cards) [cite: 702-703, 714, 719] */
QFrame#frame, QFrame#frame_3 {
    background-color: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
}

/* 4. Tiêu đề các khối con [cite: 703-704, 715, 720] */
QLabel#lblDanhSachSP, QLabel#lblThongTinChung {
    font-size: 17px;
    font-weight: 700;
    color: #111827;
    background-color: transparent;
    border: none;
    margin-bottom: 5px;
}

/* 5. Nhãn mô tả thuộc tính (Labels) [cite: 704-705, 721-726] */
QLabel#lblMaSP, QLabel#lblTenSP, QLabel#lblNgayApDung, 
QLabel#lblGiaTriGiam, QLabel#lblGiaKM {
    font-size: 13px;
    font-weight: 600; /* Semi-bold */
    color: #4b5563;   /* Màu xám đậm chuyên nghiệp */
}

/* 6. Nhãn hiển thị giá trị thực tế (Values) [cite: 705-706, 726-731] */
QLabel#lblHienThiMaSP, QLabel#lblHienThiTenSP, QLabel#lblHienThiNgayApDung, 
QLabel#lblHienThiGiaTriGiam, QLabel#lblHienThiGiaKM {
    font-size: 14px;
    font-weight: 500;
    color: #111827;
    padding: 5px 0px;
}

/* 7. Nút bấm (Ví dụ: Nút Sửa) [cite: 706-708, 713-714] */
QPushButton#btnSua {
    background-color: #2563eb; /* Xanh dương thương hiệu */
    color: #ffffff;
    font-weight: 700;
    border-radius: 8px;
    padding: 8px 20px;
}

QPushButton#btnSua:hover {
    background-color: #1d4ed8;
}

/* 8. Bảng danh sách khuyến mãi [cite: 708-712, 715-718] */
QTableWidget#tblDanhSachSP {
    background-color: #ffffff;
    border: none;
    gridline-color: transparent;
    outline: none;
}

QHeaderView::section {
    background-color: #ffffff;
    padding: 12px;
    border: none;
    border-bottom: 2px solid #f3f4f6;
    font-weight: bold;
    color: #6b7280;
    text-transform: uppercase; /* BUỘC IN HOA TIÊU ĐỀ CỘT */
    font-size: 11px;
}</string>
