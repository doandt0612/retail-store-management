  <property name="styleSheet">
   <string notr="true">/* 1. Tổng thể Cửa sổ Dialog  */
QDialog {
    background-color: #ffffff;
    font-family: &quot;Inter&quot;, &quot;Segoe UI&quot;, sans-serif;
}

/* 2. Tiêu đề chính (Thêm sản phẩm)  */
QLabel#lblTitleThemSP {
    font-size: 20px;
    font-weight: 700;
    color: #111827;
    padding-bottom: 10px;
    margin-bottom: 15px;
}

/* 3. Nhãn thuộc tính trong Form [cite: 47, 48, 49] */
QLabel#lblMaSP, QLabel#lblTenSP, QLabel#lblDanhMuc, QLabel#lblGia, 
QLabel#lblNCC, QLabel#lblSoLuong {
    font-size: 13px;
    font-weight: 600;
    color: #4b5563;
}

/* 4. Các ô nhập liệu (Inputs, ComboBox, SpinBox) [cite: 49, 50] */
QLineEdit, QComboBox, QSpinBox {
    background-color: #f9fafb;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    padding: 8px 12px;
    color: #111827;
    min-height: 25px;
}

/* Hiệu ứng khi người dùng tương tác */
QLineEdit:focus, QComboBox:focus, QSpinBox:focus {
    border: 2px solid #2563eb;
    background-color: #ffffff;
}

/* 5. Nút bấm chức năng [cite: 50, 51] */

/* Nút LƯU (Primary Button) [cite: 51] */
QPushButton#btnLuu {
    background-color: #2563eb;
    color: #ffffff;
    font-weight: 700;
    border-radius: 8px;
    padding: 12px 24px;
    min-width: 120px;
}

QPushButton#btnLuu:hover {
    background-color: #1d4ed8;
}

/* Nút HỦY (Secondary Button) [cite: 51] */
QPushButton#btnHuy {
    background-color: #ffffff;
    color: #374151;
    border: 1px solid #d1d5db;
    border-radius: 8px;
    padding: 12px 24px;
}

QPushButton#btnHuy:hover {
    background-color: #f3f4f6;
}

/* 6. Tùy chỉnh mũi tên cho ComboBox &amp; SpinBox */
QComboBox::drop-down, QSpinBox::up-button, QSpinBox::down-button {
    border: none;
    background: transparent;
}</string>
  </property>
