  <property name="styleSheet">
   <string notr="true">/* 1. Tổng thể Cửa sổ [cite: 638-640] */
QDialog {
    background-color: #f3f4f6;
    font-family: &quot;Inter&quot;, &quot;Segoe UI&quot;, sans-serif;
}

/* 2. Tiêu đề trang chính (Nén chiều cao) [cite: 640-641] */
QLabel#lblChiTietSanPham {
    font-size: 22px; /* Giảm từ 26px để tiết kiệm chỗ */
    font-weight: 800;
    color: #111827;
    padding: 5px 0px; /* Thu hẹp lề trên dưới */
}

/* 3. Thẻ nội dung (Cards) [cite: 641-642] */
QFrame#frame, QFrame#frame_2, QFrame#frame_3 {
    background-color: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
}

/* 4. Tiêu đề các khối con [cite: 642-644] */
QLabel#lblChiTietSP, QLabel#lblLichSuBanHang, QLabel#lblLichSuNhapHang {
    font-size: 15px; /* Thu nhỏ để cân đối */
    font-weight: 700;
    color: #111827;
    margin-bottom: 2px;
}

/* 5. Nhãn mô tả thuộc tính (Labels - Key) [cite: 644-645, 657-658, 660, 663, 666, 671, 673, 676] */
QLabel#lblDonGia, QLabel#lblSoLuongBan, QLabel#lblNgayMua, QLabel#lblMaDon_2,
QLabel#lblGiaNhap, QLabel#lblNgayNhap, QLabel#lblMaDonNhap {
    font-size: 12px;
    font-weight: 600;
    color: #4b5563;
}

/* 6. Nhãn hiển thị dữ liệu (Values - Nén tối đa) [cite: 645-646, 659, 661, 664, 667, 672, 674, 677] */
QLabel#lblHienThiDonGia, QLabel#lblHienThiSoLuongBan, QLabel#lblHienThiNgayMua, 
QLabel#lblHienThiMaDon, QLabel#lblHienThiGiaNhap, QLabel#lblHienThiNgayNhap, 
QLabel#lblHienThiMaDonNhap {
    font-size: 13px;
    font-weight: 500;
    color: #111827;
    padding: 1px 0px; /* Ép sát các dòng dữ liệu với nhau */
}

/* 7. Nút bấm (Sửa) [cite: 646-648] */
QPushButton#btnSua {
    background-color: #2563eb;
    color: #ffffff;
    font-weight: 700;
    border-radius: 8px;
    padding: 6px 16px;
}

QPushButton#btnSua:hover {
    background-color: #1d4ed8;
}

/* 8. Bảng chi tiết sản phẩm  */
QTableWidget#tableWidget {
    background-color: #ffffff;
    border: none;
    gridline-color: transparent;
}

QHeaderView::section {
    background-color: #ffffff;
    padding: 8px;
    border: none;
    border-bottom: 2px solid #f3f4f6;
    font-weight: bold;
    color: #6b7280;
    text-transform: uppercase;
    font-size: 10px;
}</string>
