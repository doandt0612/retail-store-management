<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>Dialog</class>
 <widget class="QDialog" name="Dialog">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>400</width>
    <height>300</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>Dialog</string>
  </property>
  <property name="styleSheet">
   <string notr="true">/* 1. Tổng thể Cửa sổ Dialog */
QDialog#Dialog {
    background-color: #ffffff;
    font-family: &quot;Inter&quot;, &quot;Segoe UI&quot;, sans-serif;
}

/* 2. Tiêu đề chính (Chỉnh sửa khách hàng) */
QLabel#lblTitleChinhSuaKH {
    font-size: 20px;
    font-weight: 700; /* Bold */
    color: #111827;
    padding-bottom: 10px;
    margin-bottom: 15px;
}

/* 3. Nhãn thuộc tính trong Form */
QLabel#lblTenKH, QLabel#lblSDTKH, QLabel#lblMaKH {
    font-size: 13px;
    font-weight: 600; /* Semi-bold */
    color: #4b5563;
}

/* 4. Ô nhập liệu và ComboBox */
QLineEdit, QComboBox {
    background-color: #f9fafb;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    padding: 10px 12px;
    color: #111827;
    min-height: 20px;
}

/* Hiệu ứng khi nhấn vào ô nhập liệu */
QLineEdit:focus, QComboBox:focus {
    border: 2px solid #2563eb;
    background-color: #ffffff;
}

/* 5. Nút bấm chức năng */

/* Nút LƯU (Xanh dương) */
QPushButton#btnLuu {
    background-color: #2563eb;
    color: #ffffff;
    font-weight: 700;
    border-radius: 8px;
    padding: 12px 24px;
    min-width: 120px;
}

QPushButton#btnLuu:hover {
    background-color: #1d4ed8;
}

/* Nút HỦY (Trắng viền xám) */
QPushButton#btnHuy {
    background-color: #ffffff;
    color: #374151;
    border: 1px solid #d1d5db;
    border-radius: 8px;
    padding: 12px 24px;
}

QPushButton#btnHuy:hover {
    background-color: #f3f4f6;
}

</string>
  </property>
