  <property name="styleSheet">
   <string notr="true">/* 1. Tổng thể Cửa sổ [cite: 318-319] */
QDialog {
    background-color: #f3f4f6; /* Nền xám nhạt làm nổi bật các Card trắng */
    font-family: &quot;Inter&quot;, &quot;Segoe UI&quot;, sans-serif;
}

/* 2. Tiêu đề trang chính (Nổi bật nhất) [cite: 320-321] */
QLabel#lblTitleLichSuMuaHang {
    font-size: 26px;
    font-weight: 800;
    color: #111827;
    padding: 10px 0px;
}

/* 3. Thẻ nội dung (Cards) [cite: 321-322] */
QFrame#frame, QFrame#frame_2 {
    background-color: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
}

/* 4. Tiêu đề các khối con [cite: 322-323] */
QLabel#lblThongTinCaNhan, QLabel#lblLichSuMuaHang {
    font-size: 17px;
    font-weight: 700;
    color: #111827;
    border: none;
    background-color: transparent;
}

/* 5. Nhãn mô tả (Labels - Thuộc tính) [cite: 323-324] */
QLabel#lblMaKH, QLabel#lblTenKH, QLabel#lblSDT {
    font-size: 13px;
    font-weight: 600;
    color: #4b5563; /* Màu xám đậm chuyên nghiệp */
}

/* 6. Nhãn hiển thị giá trị (Values - Dữ liệu) [cite: 324-325] */
QLabel#lblHienThiMaKH, QLabel#lblHienThiTenKH, QLabel#lblHienThiSDT {
    font-size: 14px;
    font-weight: 500;
    color: #111827;
    padding: 5px 0px;
}

/* 7. Bảng danh sách mua hàng [cite: 326-327] */
QTableWidget#tblDanhSachMuaHang {
    background-color: #ffffff;
    border: none;
    gridline-color: transparent; /* Xóa lưới cho sạch sẽ */
    outline: none;
}

QHeaderView::section {
    background-color: #ffffff;
    padding: 12px;
    border: none;
    border-bottom: 2px solid #f3f4f6;
    font-weight: bold;
    color: #6b7280;
    text-transform: uppercase; /* BUỘC IN HOA TIÊU ĐỀ CỘT */
    font-size: 11px;
}

/* Hiệu ứng chọn dòng */
QTableWidget#tblDanhSachMuaHang::item:selected {
    background-color: #eff6ff;
    color: #2563eb;
}</string>
  </property>
