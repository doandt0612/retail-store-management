  <property name="styleSheet">
   <string notr="true">/* 1. Tổng thể Cửa sổ  */
QDialog {
    background-color: #f3f4f6;
    font-family: &quot;Inter&quot;, &quot;Segoe UI&quot;, sans-serif;
}

/* 2. Tiêu đề trang chính (Cấp 800) [cite: 510-511] */
QLabel#lblTitleChinhSuaNV {
    font-size: 26px;
    font-weight: 800;
    color: #111827;
    padding: 10px 0px;
}

/* 3. Thẻ nội dung (Cards) [cite: 511-512] */
QFrame#frame_2, QFrame#frame_3 {
    background-color: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
}

/* 4. Tiêu đề các khối con (Cấp 700) [cite: 512-513] */
QLabel#lblThongTinCoBan, QLabel#lblThongTinHopDong {
    font-size: 17px;
    font-weight: 700;
    color: #111827;
    margin-bottom: 5px;
}

/* 5. Nhãn thuộc tính (Cấp 600) [cite: 513-514, 530, 537-538] */
QLabel#lblMaDon, QLabel#lblTenNV, QLabel#lblSDT, QLabel#lblEmail, 
QLabel#lblTrangThai, QLabel#lblLoaiNV_2, QLabel#lblChucVu, QLabel#lblLuongCoBan {
    font-size: 13px;
    font-weight: 600;
    color: #4b5563; /* Xám đậm chuyên nghiệp */
}

/* 6. Ô nhập liệu và Chọn lựa (Inputs) [cite: 514-516] */
QLineEdit, QComboBox {
    background-color: #f9fafb;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    padding: 8px 12px;
    color: #111827;
    font-size: 14px;
}

/* Hiệu ứng focus [cite: 516-517] */
QLineEdit:focus, QComboBox:focus {
    border: 2px solid #2563eb;
    background-color: #ffffff;
}

/* Ô chỉ đọc (Mã nhân viên) [cite: 517-518] */
QLineEdit[readOnly=&quot;true&quot;] {
    background-color: #f3f4f6;
    color: #6b7280;
    border: 1px dashed #d1d5db;
}

/* 7. Các nút bấm hành động [cite: 518-522] */
QPushButton#btnLuu {
    background-color: #2563eb;
    color: #ffffff;
    font-weight: 700;
    border-radius: 8px;
    padding: 10px 20px;
}

QPushButton#btnLuu:hover {
    background-color: #1d4ed8;
}

QPushButton#btnHuy {
    background-color: #ffffff;
    color: #374151;
    border: 1px solid #d1d5db;
    border-radius: 8px;
    padding: 10px 20px;
}

QPushButton#btnHuy:hover {
    background-color: #f9fafb;
}</string>
