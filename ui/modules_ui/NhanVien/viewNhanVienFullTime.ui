  <property name="styleSheet">
   <string notr="true">/* 1. Tổng thể Cửa sổ [cite: 489-490] */
QDialog {
    background-color: #f3f4f6; /* Nền xám nhạt làm nổi bật các thẻ trắng */
    font-family: &quot;Inter&quot;, &quot;Segoe UI&quot;, sans-serif;
}

/* 2. Tiêu đề trang chính (Cấp 800) [cite: 490-491] */
QLabel#lblTitleChiTietNV {
    font-size: 26px;
    font-weight: 800; /* Extra bold */
    color: #111827;
    padding: 10px 0px;
}

/* 3. Thẻ nội dung (Cards) [cite: 491-492] */
QFrame#frame_2, QFrame#frame_3 {
    background-color: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 12px; /* Bo góc đồng bộ toàn hệ thống */
}

/* 4. Tiêu đề các khối con (Cấp 700) [cite: 492-493] */
QLabel#lblThongTinCoBan, QLabel#lblThongTinHopDong {
    font-size: 17px;
    font-weight: 700;
    color: #111827;
    background: transparent;
    border: none;
    margin-bottom: 5px;
}

/* 5. Nhãn thuộc tính (Labels - Cấp 600) [cite: 493-494] */
QLabel#lblMaDon, QLabel#lblTenNV, QLabel#lblSDT, QLabel#lblEmail, 
QLabel#lblTrangThai, QLabel#lblLoaiNV_2, QLabel#lblChucVu, QLabel#lblLuongCoBan {
    font-size: 13px;
    font-weight: 600;
    color: #4b5563; /* Màu xám đậm giúp dịu mắt */
}

/* 6. Nhãn hiển thị dữ liệu (Values - Cấp 500) [cite: 494-495] */
QLabel#lblHienThiMaNV, QLabel#lblHienThiTenNV, QLabel#lblHienThiSDT, 
QLabel#lblHienThiEmail, QLabel#lblHienThiTrangThai, QLabel#lblHienThiLoaiNV_2, 
QLabel#lblHienThiChucVu, QLabel#lblHienThiLuongCoBan {
    font-size: 14px;
    font-weight: 500;
    color: #111827;
    padding: 5px 0px;
}

/* 7. Nút bấm Sửa [cite: 495-497] */
QPushButton#btnSua {
    background-color: #2563eb;
    color: #ffffff;
    font-weight: 700;
    border-radius: 8px;
    padding: 8px 20px;
}

QPushButton#btnSua:hover {
    background-color: #1d4ed8;
}</string>
