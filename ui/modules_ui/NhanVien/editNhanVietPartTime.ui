  <property name="styleSheet">
   <string notr="true">/* 1. Tổng thể [cite: 505-507] */
QDialog {
    background-color: #f3f4f6;
    font-family: &quot;Inter&quot;, &quot;Segoe UI&quot;, sans-serif;
}

/* 2. Tiêu đề trang (Cấp 800) [cite: 508-509] */
QLabel#lblTitleChinhSuaNV {
    font-size: 26px;
    font-weight: 800;
    color: #111827;
}

/* 3. Thẻ nội dung (Cards) [cite: 510] */
QFrame#frame_2, QFrame#frame_3 {
    background-color: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
}

/* 4. Tiêu đề khối (Cấp 700) [cite: 511-512] */
QLabel#lblThongTinCoBan, QLabel#lblThongTinHopDong {
    font-size: 17px;
    font-weight: 700;
    color: #111827;
}

/* 5. Nhãn thuộc tính (Cấp 600) [cite: 513-514] */
QLabel#lblMaDon, QLabel#lblTenNV, QLabel#lblSDT, QLabel#lblEmail, 
QLabel#lblLoaiNV_2, QLabel#lblLuongGio, QLabel#lblSoGioLamViec, QLabel#lblTrangThai {
    font-size: 13px;
    font-weight: 600;
    color: #4b5563;
}

/* 6. Ô nhập liệu và Chọn lựa [cite: 515-518] */
QLineEdit, QComboBox {
    background-color: #f9fafb;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    padding: 8px 12px;
    font-size: 14px;
}

QLineEdit:focus, QComboBox:focus { border: 2px solid #2563eb; background-color: #ffffff; }

QLineEdit[readOnly=&quot;true&quot;] {
    background-color: #f3f4f6;
    color: #6b7280;
    border: 1px dashed #d1d5db;
}

/* 7. Các nút bấm [cite: 519-522] */
QPushButton#btnLuu {
    background-color: #2563eb;
    color: #ffffff;
    font-weight: 700;
    border-radius: 8px;
    padding: 10px 20px;
}

QPushButton#btnHuy {
    background-color: #ffffff;
    color: #374151;
    border: 1px solid #d1d5db;
    border-radius: 8px;
}</string>
