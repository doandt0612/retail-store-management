  <property name="styleSheet">
   <string notr="true">/* 1. Tổng thể Cửa sổ Dialog */
QDialog#Dialog {
    background-color: #ffffff;
    font-family: &quot;Inter&quot;, &quot;Segoe UI&quot;, sans-serif;
}

/* 2. Nội dung thông báo cảnh báo */
QLabel#lblCanhBao {
     font-size: 13px;
    font-weight: 400; /* Regular cấp độ 4 [cite: 64] */
    color: #6b7280;   /* Màu xám nhạt để làm dịu thông tin phụ */
}

/* 3. Nút XÓA (Màu đỏ rực rỡ - Red Danger) */
QPushButton#btnXoa {
    background-color: #ef4444; /* Màu đỏ thương hiệu từ Figma */
    color: #ffffff;
    font-weight: 700;
    border: none;
    border-radius: 8px; /* Bo góc đồng bộ deleteNV.png */
    padding: 12px 24px;
    min-width: 100px;
}

QPushButton#btnXoa:hover {
    background-color: #dc2626; /* Đỏ đậm hơn khi di chuột qua */
}

/* 4. Nút HỦY (Màu trắng viền xám - Secondary) */
QPushButton#btnHuy {
    background-color: #ffffff;
    color: #4b5563;
    border: 1px solid #d1d5db; /* Viền xám mảnh chuẩn Figma */
    border-radius: 8px;
    padding: 12px 24px;
    min-width: 100px;
}

QPushButton#btnHuy:hover {
    background-color: #f3f4f6; /* Xám cực nhạt khi hover */
}</string>
  </property>
  <layout class="QVBoxLayout" name="verticalLayout">
   <item>
    <widget class="QLabel" name="lblCanhBao">
     <property name="text">
      <string>Bạn có chắc chắn muốn xóa nhân viên này không? Thao tác này sẽ làm mất liên kết trong lịch sử xử lý đơn hàng và dữ liệu bảng lương liên quan. Để giữ lại lịch sử đối soát, bạn nên chuyển trạng thái sang 'Đã nghỉ việc' thay vì xóa vĩnh viễn.</string>
     </property>
     <property name="alignment">
      <set>Qt::AlignCenter</set>
     </property>
     <property name="wordWrap">
      <bool>true</bool>
     </property>
    </widget>
   </item>
   <item>
    <layout class="QHBoxLayout" name="horizontalLayout">
     <item>
      <widget class="QPushButton" name="btnXoa">
       <property name="text">
        <string>Xóa</string>
       </property>
      </widget>
     </item>
     <item>
      <widget class="QPushButton" name="btnHuy">
       <property name="text">
        <string>Hủy</string>
       </property>
      </widget>
     </item>
    </layout>
   </item>
  </layout>
 </widget>
