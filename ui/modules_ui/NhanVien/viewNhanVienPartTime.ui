  <property name="styleSheet">
   <string notr="true">/* 1. Tổng thể Cửa sổ  */
QDialog {
    background-color: #f3f4f6; /* Nền xám nhạt làm nổi bật Card trắng */
    font-family: &quot;Inter&quot;, &quot;Segoe UI&quot;, sans-serif;
}

/* 2. Tiêu đề trang chính (Cấp 800) [cite: 488-489] */
QLabel#lblTitleChiTietNV {
    font-size: 26px;
    font-weight: 800;
    color: #111827;
    padding: 10px 0px;
}

/* 3. Thẻ nội dung (Cards) [cite: 490] */
QFrame#frame_2, QFrame#frame_3 {
    background-color: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
}

/* 4. Tiêu đề các khối con (Cấp 700) [cite: 491-492] */
QLabel#lblThongTinCoBan, QLabel#lblThongTinHopDong {
    font-size: 17px;
    font-weight: 700;
    color: #111827;
    background: transparent;
    border: none;
    margin-bottom: 5px;
}

/* 5. Nhãn thuộc tính (Cấp 600) [cite: 493] */
QLabel#lblMaDon, QLabel#lblTenNV, QLabel#lblSDT, QLabel#lblEmail, 
QLabel#lblTrangThai, QLabel#lblLoaiNV_2, QLabel#lblLuongGio, 
QLabel#lblTongTienThanhToan {
    font-size: 13px;
    font-weight: 600;
    color: #4b5563; /* Màu xám đậm chuyên nghiệp */
}

/* 6. Nhãn hiển thị dữ liệu (Cấp 500) [cite: 494] */
QLabel#lblHienThiMaNV, QLabel#lblHienThiTenNV, QLabel#lblHienThiSDT, 
QLabel#lblHienThiEmail, QLabel#lblHienThiTrangThai, QLabel#lblHienThiLoaiNV_2, 
QLabel#lblHienThiLuongGio, QLabel#lblHienThiSoGioLamViec {
    font-size: 14px;
    font-weight: 500;
    color: #111827;
    padding: 5px 0px;
}

/* 7. Nút bấm Sửa [cite: 495-496] */
QPushButton#btnSua {
    background-color: #2563eb;
    color: #ffffff;
    font-weight: 700;
    border-radius: 8px;
    padding: 8px 20px;
}

QPushButton#btnSua:hover {
    background-color: #1d4ed8;
}</string>
