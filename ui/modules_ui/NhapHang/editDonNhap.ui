  <property name="styleSheet">
   <string notr="true">/* 1. Tổng thể Cửa sổ và Phông chữ [cite: 467] */
QDialog {
    background-color: #f3f4f6;
    font-family: &quot;Inter&quot;, &quot;Segoe UI&quot;, sans-serif;
}

/* 2. Tiêu đề chính trang (Sửa đơn nhập) [cite: 468, 469] */
QLabel#lblChiTietDonNhap {
    font-size: 26px;
    font-weight: 800;
    color: #111827;
    padding: 10px 0px;
}

/* 3. Thẻ nội dung (Cards) [cite: 470, 471] */
QFrame#frame, QFrame#frame_2, QFrame#frame_3 {
    background-color: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
}

/* 4. Tiêu đề các khối con [cite: 472, 473] */
QLabel#lblThemSPNhap, QLabel#lblDanhSachSPNhap, QLabel#lblThongTinChung {
    font-size: 17px;
    font-weight: 700;
    color: #111827;
    background-color: transparent;
    border: none;
    margin-bottom: 5px;
}

/* 5. Nhãn mô tả thuộc tính (Labels) [cite: 474, 475] */
QLabel#lblMaSP, QLabel#lblTenSanPham, QLabel#lblSoLuong, QLabel#lblDonGiaNhap,
QLabel#lblMaDonNhap, QLabel#lblNCC, QLabel#lblNgayNhap, 
QLabel#lblTongTien, QLabel#lblTrangThai {
    font-size: 13px;
    font-weight: 600;
    color: #4b5563;
}

/* 6. Ô nhập liệu và Chọn lựa (Inputs) */
QLineEdit, QComboBox, QSpinBox, QDateTimeEdit {
    background-color: #f9fafb;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    padding: 8px 12px;
    color: #111827;
}

QLineEdit:focus, QComboBox:focus, QDateTimeEdit:focus {
    border: 2px solid #2563eb;
    background-color: #ffffff;
}

/* 7. Các nút bấm hành động */
/* Nút chính (Lưu, Thêm) */
QPushButton#btnLuu, QPushButton#btnThem {
    background-color: #2563eb;
    color: #ffffff;
    font-weight: 700;
    border-radius: 8px;
    padding: 10px 20px;
}

QPushButton#btnLuu:hover, QPushButton#btnThem:hover {
    background-color: #1d4ed8;
}

/* Nút phụ (Hủy) */
QPushButton#btnHuy {
    background-color: #ffffff;
    color: #374151;
    border: 1px solid #d1d5db;
    border-radius: 8px;
    padding: 10px 20px;
}

QPushButton#btnHuy:hover {
    background-color: #f9fafb;
}

/* 8. Bảng danh sách sản phẩm nhập [cite: 478-480] */
QTableWidget#tblDanhSachSPNhap {
    background-color: #ffffff;
    border: none;
    gridline-color: transparent;
    outline: none;
}

QHeaderView::section {
    background-color: #ffffff;
    padding: 12px;
    border: none;
    border-bottom: 2px solid #f3f4f6;
    font-weight: bold;
    color: #6b7280;
    text-transform: uppercase;
    font-size: 11px;
}</string>
  </property>
