          <property name="styleSheet">
           <string notr="true">/* Tiêu đề trang */
QLabel#lblTitleQuanLyDH {
    font-size: 24px;
    font-weight: bold;
    color: #111827;
}

/* Nút Thêm sản phẩm màu xanh dương nổi bật */
QPushButton#btnTaoDonHang {
    background-color: #2563eb;
    color: white;
    font-weight: bold;
    border-radius: 8px;
    padding: 8px 16px;
}


/* Kiểu dáng bảng trắng tinh khôi */
QTableWidget#tblDonHang {
    background-color: white;
    border: 1px solid #f3f4f6;
    border-radius: 12px;
}

QHeaderView::section {
    background-color: white;
    padding: 15px;
    border: none;
    border-bottom: 2px solid #f3f4f6;
    font-weight: bold;
    color: #374151;
}

/* 3. KHỐI TÌM KIẾM (frTimKiem) - Thiết kế dạng Card mỏng [cite: 331, 287, 456] */
QFrame#frTimKiem {
    background-color: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    padding: 5px;
}

/* Ô nhập liệu tìm kiếm [cite: 396-402] */
QLineEdit#txtTimKiemDonHang {
    background-color: #f9fafb;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    padding: 8px 12px;
    color: #111827;
    min-width: 250px;
}

QLineEdit#txtTimKiemDonHang:focus {
    border: 2px solid #2563eb;
    background-color: #ffffff;
}

/* Bộ lọc Trạng thái (ComboBox) [cite: 403-411] */
QComboBox#cbLocTrangThai {
    background-color: #f9fafb;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    padding: 5px 15px;
    color: #4b5563;
    min-width: 150px;
}

QComboBox#cbLocTrangThai::drop-down {
    border: none;
    width: 30px;
}

QComboBox#cbLocTrangThai::down-arrow {
    image: none;
    border-left: 5px solid transparent;
    border-right: 5px solid transparent;
    border-top: 5px solid #6b7280;
    margin-right: 10px;
}

/* Nút Tìm kiếm [cite: 162, 336] */
QPushButton#btnTimKiemDonHang {
    background-color: #f3f4f6;
    color: #374151;
    border: 1px solid #d1d5db;
    border-radius: 8px;
    padding: 7px 15px;
    font-weight: 600;
}

QPushButton#btnTimKiemDonHang:hover {
    background-color: #e5e7eb;
}

/* Áp dụng cho ô chọn ngày tháng */
QDateEdit {
    background-color: #f9fafb;
    border: 1px solid #e5e7eb;
    border-radius: 8px; /* Bo góc 8px chuẩn hệ thống [cite: 282, 287] */
    padding: 6px 10px;
    color: #4b5563; /* Màu xám đậm chuyên nghiệp [cite: 290] */
    min-width: 120px;
}

QDateEdit:focus {
    border: 2px solid #2563eb; /* Xanh dương khi chọn [cite: 294] */
    background-color: #ffffff;
}

/* Tùy chỉnh nút mũi tên lịch */
QDateEdit::drop-down {
    border: none;
    width: 25px;
}</string>
          </property>
