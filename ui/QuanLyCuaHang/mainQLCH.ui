         <widget class="QWidget" name="pageSanPham">
          <property name="styleSheet">
           <string notr="true">/* Tiêu đề trang */
QLabel#lblTitleQuanLySP {
    font-size: 24px;
    font-weight: bold;
    color: #111827;
}

/* Nút Thêm sản phẩm màu xanh dương nổi bật */
QPushButton#btnThemSP {
    background-color: #2563eb;
    color: white;
    font-weight: bold;
    border-radius: 8px;
    padding: 8px 16px;
}

QPushButton#btnThemSP:hover {
    background-color: #1d4ed8;
}

/* Kiểu dáng cho các ô lọc ComboBox */
QComboBox {
    border: 1px solid #e5e7eb;
    border-radius: 6px;
    padding: 5px;
    background-color: #f9fafb;
}

/* Kiểu dáng Bảng sản phẩm sạch sẽ */
QTableWidget#tblDanhSachSP{
    background-color: white;
    border: 1px solid #f3f4f6;
    border-radius: 12px;
}

QHeaderView::section {
    background-color: white;
    padding: 12px;
    border: none;
    border-bottom: 2px solid #f3f4f6;
    font-weight: bold;
    color: #4b5563;
}

/* Nút phân trang xanh dương */
QPushButton#btnSau_2 {
    background-color: #2563eb;
    color: white;
    border-radius: 6px;
    padding: 5px 12px;
}

QPushButton#btnTruoc_2 {
    background-color: #2563eb;
    color: white;
    border-radius: 6px;
    padding: 5px 12px;
}

/* --- Ô TÌM KIẾM SẢN PHẨM --- */
QLineEdit {
    background-color: #f9fafb; /* Màu nền xám cực nhạt */
    border: 1px solid #e5e7eb; /* Viền xám mảnh */
    border-radius: 8px;        /* Bo góc 8px như Figma */
    padding: 8px 12px;         /* Khoảng cách chữ với viền */
    color: #111827;            /* Màu chữ đen đậm */
    font-size: 11px;
}

QLineEdit:focus {
    border: 2px solid #2563eb; /* Viền xanh dương khi click vào */
    background-color: white;   /* Đổi nền trắng khi nhập liệu */
}

/* --- 2 COMBO BOX (DANH MỤC &amp; NHÀ CUNG CẤP) --- */
QComboBox {
    background-color: #f9fafb;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    padding: 5px 15px;
    min-height: 13px;
    color: #4b5563;
}

QComboBox:hover {
    background-color: #f3f4f6; /* Đậm hơn một chút khi di chuột qua */
    border: 1px solid #d1d5db;
}

QComboBox::drop-down {
    border: none; /* Xóa viền của nút mũi tên */
    width: 30px;
}

/* Tùy chỉnh mũi tên xuống cho chuyên nghiệp */
QComboBox::down-arrow {
    image: none; /* Xóa icon mặc định */
    border-left: 5px solid transparent;
    border-right: 5px solid transparent;
    border-top: 5px solid #6b7280; /* Vẽ mũi tên tam giác màu xám */
    margin-right: 10px;
}

/* Kiểu dáng cho danh sách hiện ra khi click vào */
QComboBox QAbstractItemView {
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    background-color: white;
    selection-background-color: #eff6ff; /* Màu xanh nhạt khi chọn dòng */
    selection-color: #2563eb;
    outline: none;
    padding: 5px;
}

/* 3. KHỐI TÌM KIẾM (frTimKiem) - Thiết kế dạng Card mỏng [cite: 331, 287, 456] */
QFrame#frTimKiem {
    background-color: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    padding: 5px;
}

/* Ô nhập liệu tìm kiếm [cite: 396-402] */
QLineEdit#txtTimKiemSP {
    background-color: #f9fafb;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    padding: 8px 12px;
    color: #111827;
    min-width: 250px;
}

QLineEdit#txtTimKiemSP:focus {
    border: 2px solid #2563eb;
    background-color: #ffffff;
}

/* Nút Tìm kiếm [cite: 162, 336] */
QPushButton#btnTimKiemSP {
    background-color: #f3f4f6;
    color: #374151;
    border: 1px solid #d1d5db;
    border-radius: 8px;
    padding: 7px 15px;
    font-weight: 600;
}

QPushButton#btnTimKiemSP:hover {
    background-color: #e5e7eb;
}</string>
