    border: 2px solid #2563eb;
    background-color: #ffffff;
}

/* Bộ lọc Trạng thái (ComboBox) [cite: 403-411] */
QComboBox#cbLocLoaiNV {
    background-color: #f9fafb;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    padding: 5px 15px;
    color: #4b5563;
    min-width: 150px;
}

QComboBox#cbLocLoaiNV::drop-down {
    border: none;
    width: 30px;
}

QComboBox#cbLocLoaiNVi::down-arrow {
    image: none;
    border-left: 5px solid transparent;
    border-right: 5px solid transparent;
    border-top: 5px solid #6b7280;
    margin-right: 10px;
}

/* Nút Tìm kiếm [cite: 162, 336] */
QPushButton#btnTimKiemNV {
    background-color: #f3f4f6;
    color: #374151;
    border: 1px solid #d1d5db;
    border-radius: 8px;
    padding: 7px 15px;
    font-weight: 600;
}

QPushButton#btnTimKiemNV:hover {
    background-color: #e5e7eb;
}</string>
