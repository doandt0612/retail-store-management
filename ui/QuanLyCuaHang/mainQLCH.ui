          <property name="styleSheet">
           <string notr="true">/* 1. Nền toàn trang */
QWidget#pageTongQuan {
    background-color: #f3f4f6;
}

/* Tiêu đề trang */
QLabel#lblTitleDashboards {
    font-size: 24px;
    font-weight: bold;
    color: #111827;
}

/* Kiểu dáng bảng trắng tinh khôi */
QTableWidget#tblDonHangGanDay {
    background-color: white;
    border: 1px solid #f3f4f6;
    border-radius: 12px;
}

QHeaderView::section {
    background-color: white;
    padding: 15px;
    border: none;
    border-bottom: 2px solid #f3f4f6;
    font-weight: bold;
    color: #374151;
}

/* 2. Các tiêu đề khối con (Doanh thu, Top SP, Đơn hàng gần đây) */
QLabel#lblDoanhThuTheoNgay, 
QLabel#lblSPBanChay, 
QLabel#lblDonHangGanDay {
    font-size: 16px;
    font-weight: 600; /* Bold - Giúp người dùng phân tách các khu vực chức năng nhanh hơn [cite: 294, 298, 302] */
    color: #111827;   /* Đồng bộ màu đen với tiêu đề chính để nhìn chuyên nghiệp [cite: 281] */
    margin-bottom: 5px;
}

/* 4. Thẻ nội dung (Cards) [cite: 157, 198] */
QFrame#frChartDoanhThu, 
QFrame#frChartSP, 
QFrame#frame_3 {
    background-color: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
}

/* 5. CẤP 3: Tiêu đề cột của bảng (Semi-bold)  */
QHeaderView::section {
    background-color: #ffffff;
    padding: 12px;
    border: none;
    border-bottom: 2px solid #f3f4f6;
    font-weight: 600; /* Semi-bold giống các trang khác */
    color: #4b5563;  /* Màu xám đậm chuyên nghiệp */
    text-transform: uppercase;
    font-size: 11px;
}

/* 6. CẤP 4: Chữ trong bảng (Regular/Medium) [cite: 161, 253] */
QTableWidget#tblDonHangGanDay {
    background-color: transparent;
    border: none;
    color: #374151; /* Màu chữ nội dung tiêu chuẩn */
    font-weight: 400; /* Trở về độ mảnh bình thường */
}

/* Hiệu ứng khi chọn dòng [cite: 288-289] */
QTableWidget#tblDonHangGanDay::item:selected {
    background-color: #eff6ff;
    color: #2563eb;
}</string>
