         <widget class="QWidget" name="pageNhapHang">
          <property name="styleSheet">
           <string notr="true">/* 1. Thiết lập nền cho trang */
QWidget#pageNhapHang {
    background-color: #f8f9fa; /* Màu xám cực nhạt giúp thẻ trắng nổi bật [cite: 98-99] */
}

/* 2. Tiêu đề trang */
QLabel#lblTitleQuanLyNhapHang {
    font-size: 24px;
    font-weight: bold;
    color: #111827; /* Đen tuyền chuyên nghiệp [cite: 114-115, 170] */
}

/* 3. Thẻ chứa bảng (Frame) */
QFrame#frNhapHang {
    background-color: #ffffff;
    border: 1px solid #f3f4f6;
    border-radius: 12px; /* Bo góc đồng bộ với trang Sản phẩm và Đơn hàng [cite: 117, 174, 232] */
}

/* 4. Tùy chỉnh Bảng Hóa đơn */
QTableWidget#tblDanhSachNhapHang {
    background-color: white;
    border: none;
    gridline-color: transparent; /* Ẩn lưới để trông sạch sẽ [cite: 108, 133, 210] */
    outline: none;
}

/* Tiêu đề cột (Headers) */
QHeaderView::section {
    background-color: white;
    padding: 15px;
    border: none;
    border-bottom: 2px solid #f3f4f6;
    font-weight: bold;
    color: #4b5563; /* Màu xám đậm chuyên nghiệp [cite: 118, 175, 233] */
    text-transform: uppercase; /* BUỘC IN HOA TIÊU ĐỀ CỘT [cite: 67-68] */
    letter-spacing: 0.5px;
}

/* Nút Thêm nhà cung cấp màu xanh dương */
QPushButton#btnThemDonNhapHang {
    background-color: #2563eb;
    color: white;
    font-weight: bold;
    border-radius: 8px;
    padding: 8px 16px;
}

QPushButton#btnThemDonNhapHang:hover {
    background-color: #1d4ed8;
}

/* 3. KHỐI TÌM KIẾM (frTimKiem) - Thiết kế dạng Card mỏng [cite: 331, 287, 456] */
QFrame#frTimKiem {
    background-color: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    padding: 5px;
}

/* Ô nhập liệu tìm kiếm [cite: 396-402] */
QLineEdit#txtTimKiemDonNhap {
    background-color: #f9fafb;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    padding: 8px 12px;
    color: #111827;
    min-width: 250px;
}

QLineEdit#txtTimKiemDonNhap:focus {
    border: 2px solid #2563eb;
    background-color: #ffffff;
}

/* Bộ lọc Trạng thái (ComboBox) [cite: 403-411] */
QComboBox#cbLocNCC {
    background-color: #f9fafb;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    padding: 5px 15px;
    color: #4b5563;
    min-width: 150px;
}

QComboBox#cbLocNCC::drop-down {
    border: none;
    width: 30px;
}

QComboBox#cbLocNCC::down-arrow {
    image: none;
    border-left: 5px solid transparent;
    border-right: 5px solid transparent;
    border-top: 5px solid #6b7280;
    margin-right: 10px;
}

/* Nút Tìm kiếm [cite: 162, 336] */
QPushButton#btnTimKiemDonNhap {
    background-color: #f3f4f6;
    color: #374151;
    border: 1px solid #d1d5db;
    border-radius: 8px;
    padding: 7px 15px;
    font-weight: 600;
}

QPushButton#btnTimKiemDonHang:hover {
    background-color: #e5e7eb;
}

/* Áp dụng cho ô chọn ngày tháng */
QDateEdit {
    background-color: #f9fafb;
    border: 1px solid #e5e7eb;
    border-radius: 8px; /* Bo góc 8px chuẩn hệ thống [cite: 282, 287] */
    padding: 6px 10px;
    color: #4b5563; /* Màu xám đậm chuyên nghiệp [cite: 290] */
    min-width: 120px;
}

QDateEdit:focus {
    border: 2px solid #2563eb; /* Xanh dương khi chọn [cite: 294] */
    background-color: #ffffff;
}

/* Tùy chỉnh nút mũi tên lịch */
QDateEdit::drop-down {
    border: none;
    width: 25px;
}</string>
          </property>
