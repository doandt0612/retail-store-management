<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>Dialog</class>
 <widget class="QDialog" name="Dialog">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>400</width>
    <height>300</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>Dialog</string>
  </property>
  <property name="styleSheet">
   <string notr="true">/* 1. Tổng thể Cửa sổ Dialog */
QDialog#Dialog {
    background-color: #ffffff;
    font-family: &quot;Inter&quot;, &quot;Segoe UI&quot;, sans-serif;
}

/* 2. Tiêu đề chính (Chỉnh sửa nhà cung cấp) */
QLabel#lblTitleChinhSuaNCC {
    font-size: 20px;
    font-weight: 700; /* Bold cấp độ 1 */
    color: #111827;   /* Màu đen tuyền nổi bật */
    padding-bottom: 10px;
    margin-bottom: 15px;
}

/* 3. Nhãn thuộc tính trong Form (Tên, SĐT, Địa chỉ) */
QLabel#lblTenNCC, QLabel#lblSDTNCC, QLabel#lblDiaChiNCC {
    font-size: 13px;
    font-weight: 600; /* Semi-bold cấp độ 2 */
    color: #4b5563;   /* Xám đậm chuyên nghiệp */
}

/* 4. Các ô nhập liệu (Inputs) */
QLineEdit {
    background-color: #f9fafb; /* Màu nền xám cực nhạt */
    border: 1px solid #e5e7eb; /* Viền xám mảnh */
    border-radius: 8px;        /* Bo góc đồng bộ */
    padding: 10px 12px;
    color: #111827;
    min-height: 20px;
}

/* Hiệu ứng khi click vào ô nhập liệu */
QLineEdit:focus {
    border: 2px solid #2563eb; /* Viền xanh dương thương hiệu */
    background-color: #ffffff;
}

/* 5. Nút bấm chức năng (Footer Buttons) */

/* Nút LƯU (Primary Button) */
QPushButton#btnLuu {
    background-color: #2563eb;
    color: #ffffff;
    font-weight: 700;
    border-radius: 8px;
    padding: 12px 24px;
    min-width: 120px;
}

QPushButton#btnLuu:hover {
    background-color: #1d4ed8; /* Đậm hơn khi hover */
}

/* Nút HỦY (Secondary Button) */
QPushButton#btnHuy {
    background-color: #ffffff;
    color: #374151;
    border: 1px solid #d1d5db;
    border-radius: 8px;
    padding: 12px 24px;
}

QPushButton#btnHuy:hover {
    background-color: #f3f4f6;
}</string>
  </property>
  <layout class="QVBoxLayout" name="verticalLayout">
   <item>
    <widget class="QLabel" name="lblTitleChinhSuaNCC">
     <property name="text">
      <string>Chỉnh sửa nhà cung cấp</string>
     </property>
     <property name="alignment">
      <set>Qt::AlignCenter</set>
     </property>
    </widget>
   </item>
   <item>
    <layout class="QFormLayout" name="formLayout">
     <item row="0" column="0">
      <widget class="QLabel" name="lblTenNCC">
       <property name="text">
        <string>Tên</string>
       </property>
      </widget>
     </item>
     <item row="0" column="1">
      <widget class="QLineEdit" name="txtTenNCC"/>
     </item>
     <item row="1" column="0">
      <widget class="QLabel" name="lblSDTNCC">
       <property name="text">
        <string>SĐT</string>
       </property>
      </widget>
     </item>
     <item row="1" column="1">
      <widget class="QLineEdit" name="txtSDTNCC"/>
     </item>
     <item row="2" column="0">
      <widget class="QLabel" name="lblDiaChiNCC">
       <property name="text">
        <string>Địa chỉ</string>
       </property>
      </widget>
     </item>
     <item row="2" column="1">
      <widget class="QLineEdit" name="txtDiaChiNCC"/>
     </item>
    </layout>
   </item>
   <item>
    <layout class="QHBoxLayout" name="horizontalLayout">
     <item>
      <widget class="QPushButton" name="btnLuu">
       <property name="text">
        <string>Lưu thay đổi</string>
       </property>
      </widget>
     </item>
     <item>
      <widget class="QPushButton" name="btnHuy">
       <property name="text">
        <string>Hủy</string>
       </property>
      </widget>
     </item>
    </layout>
   </item>
  </layout>
 </widget>
 <resources/>
 <connections/>
</ui>
