  <property name="styleSheet">
   <string notr="true">/* 1. Tổng thể Cửa sổ */
QDialog {
    background-color: #f3f4f6; /* Nền xám nhạt làm nổi bật các Card trắng */
    font-family: &quot;Inter&quot;, &quot;Segoe UI&quot;, sans-serif;
}

/* 2. Tiêu đề Mã đơn hàng (Nổi bật nhất) */
QLabel#lblHienThiMaDon {
    font-size: 26px;
    font-weight: 800;
    color: #111827;
    padding: 10px 0px;
}

/* 3. Thẻ nội dung (Cards) [cite: 73, 77, 83] */
QFrame#frame, QFrame#frame_2, QFrame#frame_3 {
    background-color: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
}

/* 4. Tiêu đề các khối con */
QLabel#lblDanhSachSP, QLabel#lblThongTinDatHang, QLabel#lblTomTatDonHang {
    font-size: 17px;
    font-weight: 700;
    color: #111827;
    border: none;
    background-color: transparent;
}

/* 5. Nhãn mô tả (Labels) */
QLabel#lblKH, QLabel#lblNV, QLabel#lblSoMon, QLabel#lblTongCong {
    font-size: 13px;
    font-weight: 600;
    color: #4b5563; /* Màu xám đậm chuyên nghiệp */
}

/* 6. Nhãn hiển thị giá trị (Values) [cite: 80, 82, 86, 89] */
QLabel#lblHienThiKH, QLabel#lblHienThiNV, QLabel#lblHienThiSoMon {
    font-size: 14px;
    font-weight: 500;
    color: #111827;
    padding: 5px 0px;
}

/* 7. Hiển thị Tổng cộng (Nổi bật nhất trong Summary) */
QLabel#lblHienThiTongCong {
    font-size: 26px;
    font-weight: 800;
    color: #2563eb; /* Màu xanh dương thương hiệu */
}

/* 8. Bảng danh sách sản phẩm (Table) [cite: 74-76] */
QTableWidget {
    background-color: #ffffff;
    border: none;
    gridline-color: transparent; /* Xóa lưới cho sạch sẽ */
}

QHeaderView::section {
    background-color: #ffffff;
    padding: 12px;
    border: none;
    border-bottom: 2px solid #f3f4f6;
    font-weight: bold;
    color: #6b7280;
    text-transform: uppercase;
    font-size: 11px;
}</string>
