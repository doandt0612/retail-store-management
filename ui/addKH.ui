<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>Dialog</class>
 <widget class="QDialog" name="Dialog">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>400</width>
    <height>300</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>Dialog</string>
  </property>
  <property name="styleSheet">
   <string notr="true">/* 1. Tổng thể Cửa sổ Dialog */
QDialog {
    background-color: #ffffff;
    font-family: &quot;Inter&quot;, &quot;Segoe UI&quot;, sans-serif;
}

/* 2. Tiêu đề chính (Thêm khách hàng) */
QLabel#lblTitleThemKH {
    font-size: 20px;
    font-weight: 700; /* Bold */
    color: #111827;   /* Đen tuyền chuyên nghiệp */
    padding-bottom: 10px;
    margin-bottom: 15px;
}

/* 3. Nhãn thuộc tính trong Form (Tên, SĐT, Giới tính) */
QLabel#lblTenKH, QLabel#lblSDTKH, QLabel#lblGioiTinhKH {
    font-size: 13px;
    font-weight: 600; /* Semi-bold */
    color: #4b5563;   /* Xám đậm tinh tế */
}

/* 4. Ô nhập liệu và ComboBox (Inputs) */
QLineEdit, QComboBox {
    background-color: #f9fafb; /* Nền xám cực nhạt */
    border: 1px solid #e5e7eb; /* Viền xám mảnh */
    border-radius: 8px;        /* Bo góc 8px đồng bộ */
    padding: 10px 12px;
    color: #111827;
    min-height: 20px;
}

/* Hiệu ứng khi người dùng tương tác */
QLineEdit:focus, QComboBox:focus {
    border: 2px solid #2563eb; /* Viền xanh dương thương hiệu */
    background-color: #ffffff;
}

/* 5. Nút bấm chức năng (Footer Buttons) */

/* Nút LƯU (Màu xanh dương chủ đạo) */
QPushButton#btnLuu {
    background-color: #2563eb;
    color: #ffffff;
    font-weight: 700;
    border-radius: 8px;
    padding: 12px 24px;
    min-width: 120px;
}

QPushButton#btnLuu:hover {
    background-color: #1d4ed8; /* Đậm hơn khi hover */
}

/* Nút HỦY (Trắng viền xám) */
QPushButton#btnHuy {
    background-color: #ffffff;
    color: #374151;
    border: 1px solid #d1d5db;
    border-radius: 8px;
    padding: 12px 24px;
}

QPushButton#btnHuy:hover {
    background-color: #f3f4f6;
}

/* 6. Tùy chỉnh mũi tên ComboBox */
QComboBox::drop-down {
    border: none;
    width: 30px;
}

QComboBox::down-arrow {
    image: none;
    border-left: 5px solid transparent;
    border-right: 5px solid transparent;
    border-top: 5px solid #6b7280;
    margin-right: 10px;
}</string>
  </property>
  <layout class="QVBoxLayout" name="verticalLayout">
   <item>
    <widget class="QLabel" name="lblTitleThemKH">
     <property name="text">
      <string>Thêm khách hàng</string>
     </property>
     <property name="alignment">
      <set>Qt::AlignCenter</set>
     </property>
    </widget>
   </item>
   <item>
    <layout class="QFormLayout" name="formLayout">
     <item row="0" column="0">
      <widget class="QLabel" name="lblTenKH">
       <property name="text">
        <string>Tên</string>
       </property>
      </widget>
     </item>
     <item row="0" column="1">
      <widget class="QLineEdit" name="txtTenKH">
       <property name="placeholderText">
        <string>Nhập tên khách hàng</string>
       </property>
      </widget>
     </item>
     <item row="1" column="0">
      <widget class="QLabel" name="lblSDTKH">
       <property name="text">
        <string>SĐT</string>
       </property>
      </widget>
     </item>
     <item row="1" column="1">
      <widget class="QLineEdit" name="txtSDTKH">
       <property name="placeholderText">
        <string>Nhập số điện thoại</string>
       </property>
      </widget>
     </item>
     <item row="2" column="0">
      <widget class="QLabel" name="lblGioiTinhKH">
       <property name="text">
        <string>Giới tính</string>
       </property>
      </widget>
     </item>
     <item row="2" column="1">
      <widget class="QComboBox" name="cbGioiTinhKH">
       <item>
        <property name="text">
         <string>Nam</string>
        </property>
       </item>
       <item>
        <property name="text">
         <string>Nữ</string>
        </property>
       </item>
       <item>
        <property name="text">
         <string>Khác</string>
        </property>
       </item>
      </widget>
     </item>
    </layout>
   </item>
   <item>
    <layout class="QHBoxLayout" name="horizontalLayout">
     <item>
      <widget class="QPushButton" name="btnLuu">
       <property name="text">
        <string>Lưu thay đổi</string>
       </property>
      </widget>
     </item>
     <item>
      <widget class="QPushButton" name="btnHuy">
       <property name="text">
        <string>Hủy</string>
       </property>
      </widget>
     </item>
    </layout>
   </item>
  </layout>
 </widget>
 <resources/>
 <connections/>
</ui>
