    color: #374151; /* Màu xám đậm chuyên nghiệp của Figma */
}

/* Riêng các tiêu đề lớn */
QLabel#lblTitleQuanLySP, 
QLabel#lblTitleQuanLyDH, 
QLabel#lblTitleQuanLyKhoHang {
    font-size: 24px;
    font-weight: bold;
    color: #111827;
}</string>
