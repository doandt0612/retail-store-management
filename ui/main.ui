  <property name="styleSheet">
   <string notr="true">/* CẤP 1: Tiêu đề trang chính */
QLabel#lblTitleQuanLySP, QLabel#lblTitleQuanLyDH, QLabel#lblTitleQuanLyKhoHang {
    font-size: 24px;
    font-weight: 700; /* Bold */
    color: #111827;
}

/* CẤP 2: Tiêu đề cột của bảng và các nút Sidebar */
QHeaderView::section {
    font-weight: 600;           /* Semi-bold [cite: 93] */
    text-transform: uppercase;  /* BUỘC IN HOA TIÊU ĐỀ CỘT */
    letter-spacing: 0.5px;      /* Thêm chút khoảng cách chữ cho dễ đọc  */
}

/* CẤP 3: Tiêu đề ứng dụng (Hệ thống quản lý...) */
QLabel#lblTenDeTai {
    font-size: 18px;
    font-weight: 600; /* Semi-bold giúp nó nổi bật nhưng không bằng tiêu đề trang */
    color: #111827;
    padding-left: 20px;
}

/* CẤP 4: Thông tin phụ (Subtitles) */
QLabel#lblHienThiDH, QLabel#lblHienThiSP {
    font-weight: 400; /* Regular */
    color: #6b7280;   /* Màu xám giúp tạo độ nhạt ảo */
}</string>
  </property>
  <widget class="QWidget" name="centralwidget">
   <property name="styleSheet">
    <string notr="true">/* Áp dụng cho toàn bộ ứng dụng */
